{
  "name": "calien/xlsexport",
  "description": "Calien - XLS-Exporter",
  "type": "typo3-cms-extension",
  "license": "MIT",
  "authors": [
    {
      "name": "Frank Berger",
      "role": "Developer",
      "email": "fberger@sudhaus7.de"
    },
    {
      "name": "Markus Hofmann",
      "role": "Developer",
      "email": "typo3@calien.de"
    }
  ],
  "require": {
    "php": "^8.2 || ^8.3 || ^8.4 || ^8.5",
    "phpoffice/phpspreadsheet": "^3",
    "typo3/cms-backend": "^13.4 || ^14.3",
    "typo3/cms-core": "^13.4 || ^14.3",
    "typo3/cms-fluid": "^13.4 || ^14.3"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.64",
    "helmich/typo3-typoscript-lint": "^3.3",
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^11",
    "saschaegerer/phpstan-typo3": "^3",
    "typo3/testing-framework": "^9"
  },
  "autoload": {
    "psr-4": {
      "Calien\\Xlsexport\\": "Classes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Calien\\Xlsexport\\Tests\\": "Tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "typo3/cms-composer-installers": true,
      "typo3/class-alias-loader": true
    },
    "bin-dir": ".Build/bin",
    "vendor-dir": ".Build/vendor",
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "extra": {
    "typo3/cms": {
      "extension-key": "xlsexport",
      "web-dir": ".Build/Web",
      "Package": {
        "providesPackages": {
          "phpoffice/phpspreadsheet": "Resources/Private/Php/ComposerVendor"
        }
      }
    }
  }
}
