<?xml version="1.0"?>
<!--
    Boilerplate for a unit test suite setup, adapted from TYPO3 testing-framework.

    Functional tests should extend \TYPO3\TestingFramework\Core\Tests\FunctionalTestCase.
    The functional suite bootstrap lives next to this file as FunctionalTestsBootstrap.php.
-->
<phpunit
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/11.4/phpunit.xsd"
        backupGlobals="true"
        bootstrap="UnitTestsBootstrap.php"
        cacheResult="false"
        colors="true"
        processIsolation="false"
        stopOnError="false"
        stopOnFailure="false"
        stopOnIncomplete="false"
        stopOnSkipped="false"
        beStrictAboutTestsThatDoNotTestAnything="false"
        displayDetailsOnPhpunitDeprecations="true"
        failOnPhpunitDeprecation="true"
        failOnWarning="true"
        failOnRisky="true"
>
    <testsuites>
        <testsuite name="Unit tests">
            <directory suffix="Test.php">../../Tests/Unit/</directory>
        </testsuite>
    </testsuites>
    <php>
        <ini name="display_errors" value="1"/>
        <env name="TYPO3_CONTEXT" value="Testing"/>
    </php>
</phpunit>
